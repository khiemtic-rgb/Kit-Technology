---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactSection from '../../components/ContactSection.astro';
import { t } from '../../i18n';
import '../../styles/global.css';

const m = t('en');
const c = m.contact;
---

<BaseLayout title={c.title} description={c.intro} locale="en" canonicalPath="/en/contact">
  <Header slot="header" locale="en" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{c.title}</h1>
      <p class="section-intro">{c.intro}</p>
      <ContactSection locale="en" canonicalPath="/en/contact" />
    </div>
  </section>
  <Footer slot="footer" locale="en" />
</BaseLayout>
