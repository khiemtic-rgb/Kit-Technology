---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import ArticleStructuredData from '../../../../components/ArticleStructuredData.astro';
import InsightPost from '../../../../components/insights/InsightPost.astro';
import {
  findTranslationAlternate,
  getInsightSlug,
  getPublishedInsights,
  getPublishedInsightsForLocale,
  getRelatedInsights,
  insightPostPath,
} from '../../../../lib/insights';
import { insightMetaKeywords, resolveInsightOgImage } from '../../../../lib/seo';
import '../../../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getPublishedInsightsForLocale('en');
  return posts.map((entry) => ({
    params: {
      category: entry.data.category,
      slug: getInsightSlug(entry),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const published = await getPublishedInsights();
const slug = getInsightSlug(entry);
const url = insightPostPath('en', entry.data.category, slug);
const alternate = findTranslationAlternate(entry, published);
const related = getRelatedInsights(entry, published);
const body = entry.body ?? '';
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  locale="en"
  canonicalPath={url}
  image={resolveInsightOgImage(entry.data)}
  ogType="article"
  keywords={insightMetaKeywords(entry.data)}
  alternateHref={alternate ? insightPostPath(alternate.data.locale, alternate.data.category, getInsightSlug(alternate)) : undefined}
  article={{
    publishedTime: entry.data.publishDate,
    section: entry.data.section,
    tags: entry.data.tags,
  }}
>
  <ArticleStructuredData slot="head" entry={entry} body={body} />
  <Header slot="header" locale="en" />
  <InsightPost entry={entry} locale="en" body={body} related={related} />
  <Footer slot="footer" locale="en" />
</BaseLayout>
