---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n';
import '../../styles/global.css';

const m = t('en');
---

<BaseLayout title={m.about.title} locale="en" canonicalPath="/en/about">
  <Header slot="header" locale="en" />
  <section class="section">
    <div class="container prose">
      <h1 class="section-title">{m.about.title}</h1>
      <p>{m.about.p1}</p>
      <p>{m.about.p2}</p>
      <p>{m.about.p3}</p>
      <h2>{m.about.missionTitle}</h2>
      <p>{m.about.mission}</p>
      <h2>{m.about.visionTitle}</h2>
      <p>{m.about.vision}</p>
    </div>
  </section>
  <Footer slot="footer" locale="en" />
</BaseLayout>
