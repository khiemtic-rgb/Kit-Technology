---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { t } from '../../i18n';
import '../../styles/global.css';

const m = t('vi');
const p = m.products;
---

<BaseLayout title={p.title} description={p.intro} canonicalPath="/vi/san-pham">
  <Header slot="header" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{p.title}</h1>
      <p class="section-intro">{p.intro}</p>

      <article class="product-card">
        <img class="product-logo" src="/images/novixa-logo.svg" alt="Novixa" width="120" height="48" />
        <div>
          <h2>{p.novixaName}</h2>
          <p class="product-tagline">{p.novixaTagline}</p>
          <p>{p.novixaDesc}</p>
          <ul class="product-features">
            {p.novixaFeatures.map((feature) => <li>{feature}</li>)}
          </ul>
          <a class="btn btn-primary" href={p.novixaUrl} target="_blank" rel="noopener noreferrer">
            {p.novixaCta}
          </a>
        </div>
      </article>

      <div class="card" style="margin-top: 2rem">
        <h3>{p.comingTitle}</h3>
        <p>{p.comingDesc}</p>
        <p style="margin-top: 1rem">
          <a class="btn btn-secondary" href="/vi/lien-he">Liên hệ</a>
        </p>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>
