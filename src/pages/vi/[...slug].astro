---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleBody from '../../components/ArticleBody.astro';
import ContactSection from '../../components/ContactSection.astro';
import InsightGrid from '../../components/InsightGrid.astro';
import { getArticleContent } from '../../content';
import { t } from '../../i18n';
import {
  getPublishedByCategory,
  getPublishedBySection,
  getPublishedInsightsForLocale,
} from '../../lib/insights';
import { insightHubFilter, isInsightCategoryHub, isInsightsHub } from '../../lib/insight-hubs';
import { pageInsightFilter } from '../../lib/page-insights';
import { getHubChildren, getPage, getStaticSlugs, pageUrl } from '../../lib/site-map';
import '../../styles/global.css';

export function getStaticPaths() {
  return getStaticSlugs('vi').map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug!;
const page = getPage('vi', slug);
if (!page) throw new Error(`Unknown page: ${slug}`);

const m = t('vi');
const url = pageUrl('vi', slug);
const children = page.hub ? getHubChildren('vi', page.key) : [];
const article = getArticleContent('vi', page.key);
const isContact = page.key === 'company-contact';

let insightEntries = [];
const hubFilter = insightHubFilter(page.key);
const pageFilter = pageInsightFilter(page.key);

if (hubFilter?.type === 'all') {
  insightEntries = await getPublishedInsightsForLocale('vi');
} else if (hubFilter?.type === 'category') {
  insightEntries = await getPublishedByCategory('vi', hubFilter.category);
} else if (hubFilter?.type === 'section') {
  insightEntries = await getPublishedBySection('vi', hubFilter.section);
} else if (pageFilter?.type === 'category') {
  insightEntries = await getPublishedByCategory('vi', pageFilter.category);
} else if (pageFilter?.type === 'section') {
  insightEntries = await getPublishedBySection('vi', pageFilter.section);
}

const showInsightGrid =
  insightEntries.length > 0 ||
  isInsightsHub(page.key) ||
  isInsightCategoryHub(page.key) ||
  page.key === 'faq';
---

<BaseLayout
  title={page.title.vi}
  description={page.intro?.vi ?? article?.subtitle}
  locale="vi"
  canonicalPath={url}
>
  <Header slot="header" locale="vi" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{page.title.vi}</h1>
      {page.intro?.vi && !article && <p class="section-intro">{page.intro.vi}</p>}

      {
        page.key === 'novixa' && (
          <p class="section-intro">
            <a class="btn btn-primary" href="https://novixa.vn/vi" target="_blank" rel="noopener noreferrer">
              novixa.vn
            </a>
          </p>
        )
      }

      {
        page.hub && children.length > 0 && (
          <div class="hub-grid">
            {children.map((child) => (
              <a class="hub-card" href={pageUrl('vi', child.paths.vi)}>
                <h3>{child.title.vi}</h3>
                {child.intro?.vi && <p>{child.intro.vi}</p>}
              </a>
            ))}
          </div>
        )
      }

      {article && <ArticleBody article={article} />}

      {
        pageFilter && insightEntries.length > 0 && (
          <h2 class="insight-related-title">{m.insights.relatedTitle}</h2>
        )
      }

      {
        showInsightGrid ? (
          <InsightGrid
            entries={insightEntries}
            locale="vi"
            emptyMessage={m.insights.emptyCategory}
          />
        ) : null
      }

      {
        isContact && <ContactSection locale="vi" canonicalPath={url} />
      }

      {
        !page.hub && !article && !isContact && insightEntries.length === 0 && (
          <div class="card prose">
            <p>{m.content.comingSoon}</p>
            {
              page.key.startsWith('novixa') && (
                <p>
                  <a href="https://novixa.vn/vi" target="_blank" rel="noopener noreferrer">
                    {m.content.novixaExternal}
                  </a>
                </p>
              )
            }
          </div>
        )
      }
    </div>
  </section>
  <Footer slot="footer" locale="vi" />
</BaseLayout>

<style>
  .insight-related-title {
    margin: 1.75rem 0 0;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }
</style>
