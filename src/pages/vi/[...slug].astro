---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleBody from '../../components/ArticleBody.astro';
import ContactSection from '../../components/ContactSection.astro';
import { getArticleContent } from '../../content';
import { t } from '../../i18n';
import { getHubChildren, getPage, getStaticSlugs, pageUrl } from '../../lib/site-map';
import '../../styles/global.css';

export function getStaticPaths() {
  return getStaticSlugs('vi').map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug!;
const page = getPage('vi', slug);
if (!page) throw new Error(`Unknown page: ${slug}`);

const m = t('vi');
const url = pageUrl('vi', slug);
const children = page.hub ? getHubChildren('vi', page.key) : [];
const article = getArticleContent('vi', page.key);
const isContact = page.key === 'company-contact';
---

<BaseLayout
  title={page.title.vi}
  description={page.intro?.vi ?? article?.subtitle}
  locale="vi"
  canonicalPath={url}
>
  <Header slot="header" locale="vi" />
  <section class="section">
    <div class="container">
      <h1 class="section-title">{page.title.vi}</h1>
      {page.intro?.vi && !article && <p class="section-intro">{page.intro.vi}</p>}

      {
        page.key === 'novixa' && (
          <p class="section-intro">
            <a class="btn btn-primary" href="https://novixa.vn/vi" target="_blank" rel="noopener noreferrer">
              novixa.vn
            </a>
          </p>
        )
      }

      {
        page.hub && children.length > 0 && (
          <div class="hub-grid">
            {children.map((child) => (
              <a class="hub-card" href={pageUrl('vi', child.paths.vi)}>
                <h3>{child.title.vi}</h3>
                {child.intro?.vi && <p>{child.intro.vi}</p>}
              </a>
            ))}
          </div>
        )
      }

      {article && <ArticleBody article={article} />}

      {
        isContact && <ContactSection locale="vi" canonicalPath={url} />
      }

      {
        !page.hub && !article && !isContact && (
          <div class="card prose">
            <p>{m.content.comingSoon}</p>
            {
              page.key.startsWith('novixa') && (
                <p>
                  <a href="https://novixa.vn/vi" target="_blank" rel="noopener noreferrer">
                    {m.content.novixaExternal}
                  </a>
                </p>
              )
            }
          </div>
        )
      }
    </div>
  </section>
  <Footer slot="footer" locale="vi" />
</BaseLayout>
