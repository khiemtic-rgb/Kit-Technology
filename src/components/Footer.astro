---
import { t, type Locale } from '../i18n';
import { getLocaleFromPath } from '../lib/routes';

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;
const locale = localeProp ?? getLocaleFromPath(Astro.url.pathname);
const m = t(locale);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p><strong>{m.meta.siteName}</strong> — {m.meta.tagline}</p>
    <p class="muted">{m.footer.parentNote}</p>
    <p class="muted">
      <a class="footer-link" href={m.products.novixaUrl}>{m.footer.novixaLink}</a>
    </p>
    <p class="muted">© {year} {m.footer.rights}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-text);
    color: #cbd5e1;
    padding: 2.5rem 0;
    margin-top: 3rem;
    font-size: 0.9rem;
  }
  .footer-inner p {
    margin: 0.35rem 0;
  }
  .footer-link {
    color: #5eead4;
  }
  .footer-link:hover {
    color: #fff;
  }
  .muted {
    color: #94a3b8;
    font-size: 0.85rem;
  }
</style>
