---
import { formatPublishDate } from '../lib/publish';
import { getInsightSlug, insightPostPath } from '../lib/insights';
import type { InsightEntry } from '../lib/insights';
import type { Locale } from '../i18n';

interface Props {
  entry: InsightEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const slug = getInsightSlug(entry);
const href = insightPostPath(locale, entry.data.category, slug);
---

<a class="insight-card" href={href}>
  <span class="insight-card-meta">{formatPublishDate(entry.data.publishDate, locale)}</span>
  <h3 class="insight-card-title">{entry.data.title}</h3>
  <p class="insight-card-desc">{entry.data.description}</p>
</a>

<style>
  .insight-card {
    display: block;
    padding: 1.25rem;
    border-radius: var(--radius);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .insight-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .insight-card-meta {
    display: block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0.35rem;
  }

  .insight-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    line-height: 1.35;
    color: var(--color-text);
  }

  .insight-card-desc {
    margin: 0;
    font-size: 0.92rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
