---
import { buildSiteGraphStructuredData } from '../lib/site-structured-data';
import type { Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'vi' } = Astro.props;
const data = buildSiteGraphStructuredData(locale);
---

<script type="application/ld+json" set:html={JSON.stringify(data)} />
