# Cloudflare Web Analytics — Dashboard → Analytics → Web Analytics → Add site
PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# Google Search Console — Settings → Ownership verification → HTML tag
# Paste only the content= value, e.g. AbCdEf123...
PUBLIC_GOOGLE_SITE_VERIFICATION=

# OpenAI — auto-publish articles + DALL-E hero images (scripts/auto-publish.ts)
# Also add OPENAI_API_KEY in GitHub → Settings → Secrets (required for daily 06:00 ICT workflow)
OPENAI_API_KEY=
# LOCALE=vi   # default: vi only; set LOCALE=en or --locale=en for English
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=dall-e-3

# Hero images: ai (default, DALL·E per article) or pool (free, from public/images/insights/pool)
# HERO_IMAGE_MODE=ai
# HERO_IMAGE_MODE=pool

# Cloudflare Worker cron → GitHub Actions (optional, more reliable than GitHub schedule alone)
# Set in Cloudflare Dashboard → Workers → kittech → Settings → Variables → GITHUB_PAT
# Fine-grained PAT: repo Actions read+write, Contents read
