{
  "name": "kit-technology",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host localhost --port 4322",
    "build": "astro build",
    "preview": "astro preview --host localhost --port 4322",
    "deploy": "npm run build && wrangler deploy --config wrangler.jsonc",
    "cf:deploy": "wrangler deploy --config wrangler.jsonc",
    "astro": "astro",
    "content:stubs": "npx tsx scripts/generate-content-stubs.ts",
    "content:queue": "npx tsx scripts/process-content-queue.ts",
    "content:publish": "npx tsx scripts/auto-publish.ts",
    "content:publish:test": "npx tsx scripts/auto-publish.ts --id=tech-cloud-native --locale=vi --force",
    "content:status": "npx tsx scripts/content-status.ts",
    "content:verify": "npx tsx scripts/verify-publish.ts"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^6.4.7"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "wrangler": "^4.54.0"
  }
}
